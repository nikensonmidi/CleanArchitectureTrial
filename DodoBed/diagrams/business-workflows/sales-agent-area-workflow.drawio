        <mxCell id="edge-customer-quote" edge="1" parent="1" source="customer" target="quote" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=12;labelBackgroundColor=#ffffff;" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-quote-qli" edge="1" parent="1" source="quote" target="quote-line-item" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.25;exitY=1;entryX=0.5;entryY=0;fontSize=12;labelBackgroundColor=#ffffff;" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-quote-order" edge="1" parent="1" source="quote" target="order" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.75;exitY=1;entryX=0.5;entryY=0;fontSize=12;labelBackgroundColor=#ffffff;" value="1 : 0..1 (nullable)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-qli-selopt" edge="1" parent="1" source="quote-line-item" target="selected-option" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=12;labelBackgroundColor=#ffffff;" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edge-order-oli" edge="1" parent="1" source="order" target="order-line-item" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=12;labelBackgroundColor=#ffffff;" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
