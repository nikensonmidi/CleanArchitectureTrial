<mxfile host="app.diagrams.net" agent="Claude Code">
  <diagram id="product-option-hierarchy" name="Product Option Hierarchy">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1020" pageHeight="260" math="0" shadow="0" background="#141414">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Dark background -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141414;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1020" height="260" as="geometry" />
        </mxCell>

        <!-- Product box -->
        <mxCell id="product" value="Product" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=#ffffff;fontColor=#ffffff;fontFamily=Courier New;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="product-sub" value="(Horizon Set)" style="text;html=1;align=center;verticalAlign=top;fontColor=#ffffff;fontFamily=Courier New;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="180" height="20" as="geometry" />
        </mxCell>

        <!-- ProductOptionGroup box -->
        <mxCell id="group" value="ProductOptionGroup" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=#ffffff;fontColor=#ffffff;fontFamily=Courier New;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="360" y="60" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="group-sub" value="(e.g., Wood Finish)&lt;br&gt;(e.g., Case Goods)" style="text;html=1;align=center;verticalAlign=top;fontColor=#ffffff;fontFamily=Courier New;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="140" width="260" height="44" as="geometry" />
        </mxCell>

        <!-- ProductOptionValue box -->
        <mxCell id="value" value="ProductOptionValue" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=#ffffff;fontColor=#ffffff;fontFamily=Courier New;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="780" y="60" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="value-sub" value="(e.g., Solid Walnut)&lt;br&gt;(e.g., Nightstand)" style="text;html=1;align=center;verticalAlign=top;fontColor=#ffffff;fontFamily=Courier New;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="780" y="140" width="260" height="44" as="geometry" />
        </mxCell>

        <!-- Product -> ProductOptionGroup edge with 1..N cardinality -->
        <mxCell id="edge1" style="html=1;endArrow=block;strokeColor=#ffffff;fillColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#ffffff;fontFamily=Courier New;" edge="1" parent="1" source="product" target="group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge1-label-1" value="1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#ffffff;fontFamily=Courier New;fontSize=16;labelBackgroundColor=#141414;" vertex="1" connectable="0" parent="edge1">
          <mxGeometry x="-0.6" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="edge1-label-n" value="N" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#ffffff;fontFamily=Courier New;fontSize=16;labelBackgroundColor=#141414;" vertex="1" connectable="0" parent="edge1">
          <mxGeometry x="0.6" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- ProductOptionGroup -> ProductOptionValue edge with 1..N cardinality -->
        <mxCell id="edge2" style="html=1;endArrow=block;strokeColor=#ffffff;fillColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#ffffff;fontFamily=Courier New;" edge="1" parent="1" source="group" target="value">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2-label-1" value="1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#ffffff;fontFamily=Courier New;fontSize=16;labelBackgroundColor=#141414;" vertex="1" connectable="0" parent="edge2">
          <mxGeometry x="-0.6" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="edge2-label-n" value="N" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#ffffff;fontFamily=Courier New;fontSize=16;labelBackgroundColor=#141414;" vertex="1" connectable="0" parent="edge2">
          <mxGeometry x="0.6" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
